# StadiumIQ configuration — copy to .env and fill in what you have.
# The app runs fully offline with ZERO keys (deterministic mock provider).

# --- GenAI providers (optional; tried in this order) ---
# Primary: NVIDIA NIM (https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Fallback: Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Runtime ---
APP_ENV=development
LOG_LEVEL=INFO
# Requests per minute allowed per client IP on GenAI endpoints
RATE_LIMIT_PER_MINUTE=30
# Upstream LLM call timeout in seconds
LLM_TIMEOUT_SECONDS=20
# Cap on LLM completion length (tokens)
LLM_MAX_OUTPUT_TOKENS=700
